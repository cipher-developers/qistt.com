// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  firstName String
  lastName  String
  role      UserRole   @default(MANAGER)
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId])
  @@index([email])
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  subdomain       String   @unique
  ownerEmail      String
  logo            String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  customers       Customer[]
  vendors         Vendor[]
  items           Item[]
  purchases       Purchase[]
  categories      Category[]
  references      Reference[]
  installmentPlans InstallmentPlan[]
  transactions    Transaction[]
}

model Vendor {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  address   String?
  notes     String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([tenantId, phone])
}

model Customer {
  id          Int        @id @default(autoincrement())
  name        String
  phone       String
  cnic        String?
  email       String?
  address     String?
  referenceId String?
  reference   Reference? @relation(fields: [referenceId], references: [id], onDelete: SetNull)
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  installmentPlans InstallmentPlan[]
  transactions Transaction[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([referenceId])
  @@unique([tenantId, phone])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@unique([tenantId, name])
}

model Reference {
  id        String     @id @default(cuid())
  name      String
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId])
  @@unique([tenantId, name])
}

model Item {
  id         Int      @id @default(autoincrement())
  name       String
  model      String?
  description String?
  sku        String?
  costPrice  Float?
  sellingPrice Float?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases  Purchase[]
  installmentPlans InstallmentPlan[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([categoryId])
}

model Purchase {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  itemId      Int
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quantity    Int
  consumedQty Int      @default(0)
  unitCost    Float
  purchasedAt DateTime
  notes       String?
  plans       InstallmentPlan[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([vendorId])
  @@index([itemId])
}

model InstallmentPlan {
  id              Int      @id @default(autoincrement())
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  itemId          Int
  item            Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  purchaseId      Int?
  purchase        Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sellingPrice    Float
  advancePaid     Float    @default(0)
  monthlyAmount   Float
  months          Int
  startDate       DateTime
  status          String   @default("active")
  installments    Installment[]
  transactions    Transaction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([itemId])
  @@index([purchaseId])
}

model Installment {
  id              String   @id @default(cuid())
  planId          Int
  plan            InstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  installmentNumber Int
  dueDate         DateTime
  amount          Float
  paidAmount      Float    @default(0)
  status          String   @default("pending") // pending, partial, paid
  transactions    Transaction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([planId])
  @@unique([planId, installmentNumber])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  planId          Int
  plan            InstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  installmentId   String?
  installment     Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount          Float
  description     String?
  transactionDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([planId])
  @@index([installmentId])
  @@index([customerId])
}

enum UserRole {
  ADMIN
  OWNER
  MANAGER
  STAFF
}
